# MoltProof — configuration (PUBLIC inputs only; NEVER put a user's private key here)
# This service is read-only. The only "secret" it holds is its OWN verdict-signing
# key, and even that is optional — recomputability, not the signature, is the trust anchor.

PORT=3006

# --- Read-only RPC endpoints (public reads only; no signing accounts) ---
RPC_ETHEREUM=https://ethereum-rpc.publicnode.com
RPC_BASE=https://mainnet.base.org
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_OPTIMISM=https://mainnet.optimism.io
RPC_POLYGON=https://polygon-rpc.com
# Hyperliquid info endpoint (read-only)
HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info

# --- Verdict signing (Ed25519). did:web:moltrust.ch#moltproof-key-1 ---
# PKCS#8 PEM of an Ed25519 private key used ONLY to sign MoltProof's own verdicts.
# If unset, the service still returns verdicts; they are unsigned but fully recomputable.
# Provisioned by the operator at deploy time; do not commit.
MOLTPROOF_SIGNING_KEY_PEM=

# --- SSRF allowlist for DID/mandate resolution (comma-separated hostnames) ---
# Only these hosts may be fetched when resolving a DID document or mandate VC.
DID_RESOLVE_ALLOWLIST=moltrust.ch,api.moltrust.ch

# --- x402 (paid endpoints) — wired at deploy, see README ---
X402_ENABLED=false
X402_PAY_TO_ADDRESS=
X402_NETWORK=base
